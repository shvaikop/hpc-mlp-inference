	$(MAKE) $(MAKESILENT) -f CMakeFiles/mlp_infer_avx2_max.dir/build.make CMakeFiles/mlp_infer_avx2_max.dir/src/main.cpp.s
	$(MAKE) $(MAKESILENT) -f CMakeFiles/mlp_infer_custom_alloc.dir/build.make CMakeFiles/mlp_infer_custom_alloc.dir/src/main.cpp.s
	$(MAKE) $(MAKESILENT) -f CMakeFiles/mlp_infer_avx2_max_openmp.dir/build.make CMakeFiles/mlp_infer_avx2_max_openmp.dir/src/main.cpp.s
	$(MAKE) $(MAKESILENT) -f CMakeFiles/mlp_infer_mpi.dir/build.make CMakeFiles/mlp_infer_mpi.dir/src/main.cpp.s
.PHONY : src/main.cpp.s

